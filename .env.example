# Frontend (Vite exposes only VITE_-prefixed vars to the browser bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# scripts/sync-blogs.mjs only (Node-side, never bundled into the frontend).
# Secret key bypasses RLS — required to write to blog_posts.
# Get it from Supabase dashboard → Project Settings → API Keys → secret key.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx
